# Copy this file to .env and fill in your values

# ── API connection ────────────────────────────────────────────────────────────
# Base URL of your web forms backend (no trailing slash)
API_BASE_URL= http://localhost:3000

# API key for authentication (set this on your server too)
API_KEY=123456789abcdef123456789abcdef1234567890

# ── Medical Office import folder ──────────────────────────────────────────────
# Path where Medical Office watches for incoming GDT files
# Must match the Importpfad set in MO Datenpflegesystem
# GDT_IMPORT_DIR= http://localhost:3000/api/gdt/pending
GDT_IMPORT_DIR=  /Users/mahran.elmasri/Desktop/gdt-files 

# ── Polling ───────────────────────────────────────────────────────────────────
# How often to check the API for new files (milliseconds)
# 10000 = every 10 seconds — good default for a busy practice
POLL_INTERVAL_MS=10000

# Max consecutive API errors before a warning is logged
MAX_RETRIES=3

# ── Logging ───────────────────────────────────────────────────────────────────
# Leave blank to use bridge.log in the same folder as bridge.js
# LOG_FILE=C:\Logs\gdt-bridge.log